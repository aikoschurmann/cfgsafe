include "test.h"

schema AppConfig {
    int port { default: 8080, min: 1, max: 65535, validate: validate }
    float threshold { default: 0.5, min: 0.0, max: 1.0 }
    
    enum log_level { default: "info", values: ["debug", "info", "warn", "error"] }
    
    required path cert_path { must_exist: true }
    
    section database {
        required string user
        
        string[] backup_nodes { min_elems: 1 }
    }
}