import "integration_hooks.h"

schema NestedConfig {
    nested_id: int { 
        default: 99 
        hook: "test_nested_hook"
    }
    active: bool { 
        default: true 
        short: "a"
    }
}

schema TestSuite {
    project_name: string {
        required: true
        min_length: 3
        pattern: "^[A-Za-z0-9_-]+$"
    }
    
    version: int {
        default: 1
        range: 1..100
        short: "v"
    }

    api_key: string {
        secret: true
        default: "super-secret-key"
    }
    
    section level1 {
        factor: float {
            default: 0.5
            min: 0.0
            max: 1.0
        }
        
        section level2 {
            bind_addr: ipv4 {
                default: "127.0.0.1"
                env: "BIND_ADDR"
            }
            
            section level3 {
                debug_mode: bool {
                    default: false
                }
                
                log_file: path {
                    exists: true
                    required_if: debug_mode == true
                }
                
                section level4 {
                    depth: int {
                        default: 4
                    }
                    tags: string[] {
                        min_length: 1
                        hook: "test_array_hook"
                    }
                }
            }
        }
    }

    global_level: enum(DEBUG, INFO, WARN, ERROR) {
        default: INFO
    }
}

schema EdgeCaseTest {
    empty_str: string { default: "" }
    space_str: string { default: " " }
    
    // Boolean stress
    flag_true: bool { default: false }
    flag_1: bool { default: false }
    flag_false: bool { default: true }
    flag_0: bool { default: true }

    hook_field: string {
        hook: "test_hook"
        default: "hook-ok"
    }

    int_array: int[] {
        min_length: 2
    }

    // Cross reference
    sub: NestedConfig {}
    
    section weird {
        // Deeply nested under schema
        key_with_dash: string { default: "dash" }
    }
}
